{
  "name": "jhtoolbox",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "copy:pdf-worker": "node scripts/copy-pdf-worker.mjs",
    "predev": "npm run copy:pdf-worker",
    "prebuild": "npm run copy:pdf-worker",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit --incremental false -p tsconfig.typecheck.json",
    "check:url-safety": "node --experimental-strip-types scripts/checks/url-safety.check.mjs",
    "check:zip-safety": "node --experimental-strip-types scripts/checks/zip-safety.check.mjs",
    "check:spreadsheet-safety": "node --experimental-strip-types scripts/checks/spreadsheet-safety.check.mjs",
    "check:filename-safety": "node --experimental-strip-types scripts/checks/filename-safety.check.mjs",
    "check:option-schema": "node --experimental-strip-types scripts/checks/option-schema.check.mjs",
    "check:html-sanitize": "node --experimental-strip-types scripts/checks/html-sanitize.check.mjs",
    "check:pdf-page-math": "node --experimental-strip-types scripts/checks/pdf-page-math.check.mjs",
    "check:tile-math": "node --experimental-strip-types scripts/checks/tile-math.check.mjs",
    "check:media-dimensions": "node --experimental-strip-types scripts/checks/media-dimensions.check.mjs",
    "check:cms-detect": "node --experimental-strip-types scripts/checks/cms-detect.check.mjs",
    "check:pdf-reduction": "node --experimental-strip-types scripts/checks/pdf-reduction.check.mjs",
    "check:hwpx-units": "node --experimental-strip-types scripts/checks/hwpx-units.check.mjs",
    "check:hwpx-package": "node --experimental-strip-types --import ./scripts/checks/register-hooks.mjs scripts/checks/hwpx-package.check.mjs",
    "check:hwpx-text": "node --experimental-strip-types --import ./scripts/checks/register-hooks.mjs scripts/checks/hwpx-text.check.mjs",
    "check:layout-analysis": "node --experimental-strip-types scripts/checks/layout-analysis.check.mjs",
    "check:invariants": "node --experimental-strip-types scripts/checks/registry-invariants.check.mjs",
    "test:unit": "npm run check:url-safety && npm run check:zip-safety && npm run check:spreadsheet-safety && npm run check:filename-safety && npm run check:option-schema && npm run check:html-sanitize && npm run check:pdf-page-math && npm run check:tile-math && npm run check:media-dimensions && npm run check:cms-detect && npm run check:pdf-reduction && npm run check:hwpx-units && npm run check:hwpx-package && npm run check:hwpx-text && npm run check:layout-analysis && npm run check:invariants",
    "test:e2e": "playwright test",
    "verify": "npm run typecheck && npm run lint && npm run test:unit && npm run build"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@next/env": "^14.2.35",
    "browser-image-compression": "^2.0.2",
    "cal-sans": "^1.0.1",
    "exifr": "^7.1.3",
    "fabric": "^6.6.1",
    "fast-xml-parser": "^4.5.3",
    "framer-motion": "^11.15.0",
    "geist": "^1.7.0",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "next": "^14.2.26",
    "papaparse": "^5.5.2",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.8.69",
    "pica": "^9.0.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "tesseract.js": "^6.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.3.15",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.26",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}
